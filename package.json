{
  "name": "auto-qris",
  "version": "2.0.0",
  "description": "QRIS Static to Dynamic converter — parse, validate, and convert Indonesian QRIS payment codes",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "bun run build && wrangler dev",
    "cli": "tsx src/cli.ts",
    "deploy": "bun run build && wrangler deploy"
  },
  "keywords": [
    "qris",
    "qr-code",
    "payment",
    "indonesia",
    "emvco",
    "gpn"
  ],
  "author": "Gidhan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/verssache/qris-dinamis"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "wrangler": "^4.83.0"
  }
}
